# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.

aws_region  = "us-east-1"
aws_profile = "infra-setup-user"

project_name = "usermgmt-ecs"

# Required: choose a strong password (8+ chars, no '/', '@', '"', or spaces).
db_password = "ChangeMe_StrongPassword1"

# EC2 capacity for the ECS cluster.
instance_type    = "t3.small"
desired_capacity = 2

# Lock the ALB down to your IP for a private demo, e.g. "203.0.113.4/32".
allowed_cidr = "0.0.0.0/0"

image_tag = "latest"
