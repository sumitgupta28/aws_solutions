# Copy to terraform.tfvars and adjust. terraform.tfvars is gitignored.

aws_region  = "us-east-1"
aws_profile = "infra-setup-user"

project_name    = "usermgmt-eks"
cluster_version = "1.30"

# Required: choose a strong password (8+ chars, no '/', '@', '"', or spaces).
db_password = "ChangeMe_StrongPassword1"

# Managed node group sizing.
instance_type    = "t3.small"
desired_capacity = 2

image_tag = "latest"
